<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assignment5.View.ShoppingItems"
             Title="ShoppingItems"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,8" Spacing="4">
            <Label Text="🛒 Shopping Items"
                   FontSize="24"
                   FontAttributes="Bold"/>
            <Label Text="Tap 'Add to Cart' to add items"
                   FontSize="13"
                   TextColor="Gray"/>
        </VerticalStackLayout>

        <Button Grid.Row="1"
                Text="View Cart 🛍️"
                Clicked="OnViewCartClicked"
                BackgroundColor="#1a73e8"
                TextColor="White"
                CornerRadius="20"
                HeightRequest="42"
                Margin="16,0,16,10"/>

        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="Green"/>

        <CollectionView Grid.Row="2"
                        x:Name="ItemsCollection"
                        ItemsSource="{Binding Items}"
                        Margin="12,0,12,12"
                        SelectionMode="Single"
                        SelectionChanged="OnItemSelectionChanged">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     Margin="0,60,0,0">
                    <Label Text="📦" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="No items found"
                           FontSize="16"
                           TextColor="Gray"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#e0e0e0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14"
                            Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto">

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="17"
                                   FontAttributes="Bold"/>

                            <Image Grid.Row="0" Grid.Column="0" Source="{Binding ImageLink}" HeightRequest="160" />

                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="#e8f5e9"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="8,4">
                                <Label Text="{Binding Price, StringFormat='R{0:N2}'}"
                                       TextColor="#2e7d32"
                                       FontAttributes="Bold"
                                       FontSize="14"/>
                            </Border>

                            <Label Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="Gray"
                                   Margin="0,4,0,4"/>

                            <Label Grid.Row="2" Grid.ColumnSpan="2"
                                   Text="{Binding Quantity, StringFormat='In stock: {0}'}"
                                   FontSize="12"
                                   TextColor="#888"/>

                            <!-- ✅ No CommandParameter needed -->
                            <Button Grid.Row="3" Grid.ColumnSpan="2"
                                    Text="Add to Cart"
                                    BackgroundColor="Green"
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="42"
                                    Margin="0,8,0,0"
                                    Clicked="OnAddToCartClicked"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>