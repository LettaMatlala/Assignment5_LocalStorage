<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Assignment5.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Assignment5.View"
    Title="Assignment5">

    <!-- Shell TabBar-->
    <TabBar>
        <Tab Title="Shop" Route="ShoppingItems" Icon="shoppingcart.png">
            <ShellContent 
            ContentTemplate="{DataTemplate local:ShoppingItems}"
            Route="ShoppingItems"/>
        </Tab>

        <Tab Title="Cart" Route="Cart" Icon="email.png">
            <ShellContent 
            ContentTemplate="{DataTemplate local:ShoppingCart}"
            Route="ShoppingCart"/>
        </Tab>

        <Tab Title="Profile" Route="MainPage" Icon="profileicon.png">
            <ShellContent
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage"/>
        </Tab>
    </TabBar>

</Shell>
