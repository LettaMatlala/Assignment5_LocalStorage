<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Assignment5.MainPage"
             Shell.NavBarIsVisible="False">

    <!-- ScrollView allows the page to scroll if content is longer than screen -->
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <!--Title-->
            <Label Text="Profile"
                   FontSize="20"
                   FontAttributes="Bold"/>

            <!-- Profile picture display -->
            <Border x:Name="PictureBorder"
                    Stroke="HotPink"
                    HeightRequest="120" 
                    WidthRequest="120"
                    StrokeThickness="3"
                    StrokeShape="RoundRectangle 100">
            <Image x:Name="ProfileImage" 
                   Source="profileicon.png"
                   HeightRequest="120" 
                   WidthRequest="120" 
                   Aspect="AspectFill"/>
            </Border>
            
            <Button Text="Change Picture" 
                    BackgroundColor="HotPink"
                    TextColor="White"
                    MaximumHeightRequest="40"
                    CornerRadius="25"
                    WidthRequest="130"
                    Clicked="OnChooseImageClicked"/>

            <!-- Input fields with borders -->
            <Border Stroke="HotPink" StrokeThickness="1" StrokeShape="RoundRectangle 25"  Margin="0,20,0,0">
                <Entry x:Name="NameEntry" Placeholder="Name"
                       Margin="10,0,0,0"/>
            </Border>

            <Border Stroke="HotPink" StrokeThickness="1" StrokeShape="RoundRectangle 25">
                <Entry x:Name="SurnameEntry" Placeholder="Surname" Margin="10,0,0,0"/>
            </Border>

            <Border Stroke="HotPink" StrokeThickness="1" StrokeShape="RoundRectangle 25">
                <Entry x:Name="EmailEntry" Placeholder="Email" Margin="10,0,0,0"/>
            </Border>

            <Border Stroke="HotPink" StrokeThickness="1" StrokeShape="RoundRectangle 25">
                <Editor x:Name="BioEditor" Placeholder="Bio" HeightRequest="100" Margin="10,0,0,0"/>
            </Border>




            <!-- Save button -->
            <Button Text="Save" 
                    TextColor="White"
                    BackgroundColor="HotPink"
                    Clicked="OnSaveClicked"
                    Margin="0,30,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
